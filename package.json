{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "dev": "vite",
        "start": "npm-run-all --parallel dev serve",
        "serve": "php artisan serve",
        "serve_sharing": "dotenv -e .env -- node -e \"require('child_process').execSync(`php artisan serve --host=${process.env.MY_IP} --port=8000`, { stdio: 'inherit' })\"",
        "clear-cache": "php artisan cache:clear && php artisan config:clear && php artisan route:clear && php artisan view:clear",
        "migration-seeder": "php artisan migrate:fresh --seed"
    },
